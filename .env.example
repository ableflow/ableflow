# 국가법령정보 공동활용 Open API 인증값 (open.law.go.kr 에서 발급받은 이메일 아이디 앞부분)
LAW_API_OC=

# AI 제공사: anthropic | openai
AI_PROVIDER=anthropic

# Claude API 키
ANTHROPIC_API_KEY=

# OpenAI API 키 (추후 확장용, 선택)
OPENAI_API_KEY=

# 사용할 모델명 (예: claude-3-5-sonnet-latest)
AI_MODEL=claude-3-5-sonnet-latest

# ── 데이터베이스 ──────────────────────────────────────────────
# 로컬 개발: 비워두면 자동으로 data/ablelaw.db 파일을 사용합니다.
# Vercel 등 클라우드 배포: Turso(libsql) 주소와 토큰을 지정하세요.
#   turso db create ablelaw && turso db show ablelaw --url && turso db tokens create ablelaw
DATABASE_URL=
DATABASE_AUTH_TOKEN=
